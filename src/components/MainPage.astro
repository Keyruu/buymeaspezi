---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: 'de' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="w-screen flex justify-center items-center h-full">
  <div class="grid max-w-screen-xl px-4 py-8 mx-auto lg:gap-8 xl:gap-0 lg:py-16 lg:grid-cols-12">
    <div class="order-2 mr-auto place-self-center lg:order-1 lg:col-span-7">
      <h1 class="max-w-2xl mb-4 text-4xl font-extrabold tracking-tight leading-none md:text-5xl xl:text-6xl dark:text-white">
        <span class="wave-text">Paulaner Spezi</span> - {t('tagLine')}
        <span class="text-[#D1B000] dark:text-[#FFD700]">{t('gold')}</span>
      </h1>
      <p class="max-w-2xl mb-6 font-light text-gray-500 lg:mb-8 md:text-lg lg:text-xl dark:text-gray-300">
        {t('cheesy')}
      </p>
      <div class="flex flex-row items-center">
        <div class="inline-flex rounded-md shadow-sm" role="group">
          <button type="button" class="px-5 py-3 text-sm font-medium text-gray-900 bg-white border border-gray-200 rounded-s-lg hover:bg-gray-100 dark:bg-gray-700 dark:text-white dark:border-gray-600 dark:hover:bg-gray-600" id="decrease-btn">
            -
          </button>
          <button type="button" class="px-5 py-3 text-sm font-medium text-gray-900 bg-white border-t border-b border-gray-200 dark:bg-gray-700 dark:text-white dark:border-gray-600">
            <span id="amount">1</span>
          </button>
          <button type="button" class="px-5 py-3 text-sm font-medium text-gray-900 bg-white border border-gray-200 rounded-e-lg hover:bg-gray-100 dark:bg-gray-700 dark:text-white dark:border-gray-600 dark:hover:bg-gray-600" id="increase-btn">
            +
          </button>
        </div>
        <a id="paypal-link" target="_blank" href="https://paypal.me/lucaskeyruu/1" class="ml-4 px-5 py-3 rounded-lg bg-gradient-to-r from-paypal-400 to-paypal-600 hover:from-paypal-500 hover:to-paypal-700 text-white font-medium">
          {t('paypal')}
        </a>
      </div>
    </div>
    <div class="order-1 flex justify-center px-24 lg:p-0 mb-6 lg:m-0 lg:order-2 lg:mt-0 lg:col-span-5">
      <img
        src="/paulanerspezi.png"
        alt="Spezi"
        class="object-contain"
        width="1000"
        height="1550"
        loading="eager"
      />
    </div>
  </div>
</section>

<script>
  let amount = 1;
  
  document.getElementById('decrease-btn')?.addEventListener('click', () => {
    if (amount > 1) amount--;
    updateDisplay();
  });
  
  document.getElementById('increase-btn')?.addEventListener('click', () => {
    amount++;
    updateDisplay();
  });
  
  function updateDisplay() {
    const el = document.getElementById('amount');
    const link = document.getElementById('paypal-link');
    if (el) el.textContent = amount.toString();
    if (link) link.href = `https://paypal.me/lucaskeyruu/${amount}`;
  }
</script>

<style>
  .wave-text {
    background: linear-gradient(
      90deg,
      #efd359,
      #df8051,
      #d64f60,
      #ca468f,
      #5c4693
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
</style>
